{
  "permissions": {
    "allow": [
      "Bash(flutter:*)",
      "Bash(cd:*)",
      "Bash(adb:*)",
      "Bash(gh:*)",
      "Bash(gh repo create:*)",
      "Bash(gh repo view:*)",
      "Bash(echo:*)",
      "Skill(gsd:discuss-phase)",
      "Skill(gsd:discuss-phase:*)",
      "Skill(gsd:plan-phase)",
      "Skill(gsd:plan-phase:*)"
    ]
  },
  "model": "opus",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"C:\\Users\\olegn\\.claude\\notification.ps1\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "C:\\Users\\olegn\\.local\\bin\\dcg.exe"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:\\Users\\olegn\\.claude\\hooks\\gsd-check-update.js\""
          }
        ]
      }
    ],
    "PostToolUse": []
  },
  "statusLine": {
    "type": "command",
    "command": "node \"C:\\Users\\olegn\\.claude\\hooks\\gsd-statusline.js\""
  },
  "enabledPlugins": {
    "playwright@claude-plugins-official": true
  }
}
